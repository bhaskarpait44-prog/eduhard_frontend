# EduCore Frontend — Environment Variables
# Copy this file to .env.local for local overrides (never commit .env.local)

# Backend API base URL — matches your Node.js server from Step 9
VITE_API_BASE_URL=http://localhost:5000/api

# App name (shown in title bar and sidebar)
VITE_APP_NAME=EduCore

# App version
VITE_APP_VERSION=1.0.0
